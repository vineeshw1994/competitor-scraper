# Local runs only — never commit .env (see .gitignore)
# GitHub Actions uses Settings → Secrets (DB_HOST, DB_USER, etc.)

# WordPress staging DB (erbeaaustu) — Cloudways → Application → Access Details
DB_HOST=52.56.159.106
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=erbeaaustu
DB_TABLE_PREFIX=wp_

SCRAPER_THRESHOLD=50
DEEP_MAX_COMPS_PER_SITE=3
REQUEST_DELAY_MS=2500

# Optional — only needed on datacenter servers blocked by Cloudflare (not GitHub Actions)
# SCRAPER_PROXY=http://user:pass@gate.smartproxy.com:10000
