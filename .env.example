# Scraper app database (Cloudways phpstack — same as LWD_COMPETITOR_DB_* in wp-config)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=wftxhgbmuh
DB_PASSWORD=your_password_from_cloudways
DB_NAME=wftxhgbmuh
DB_TABLE_PREFIX=wp_
SCRAPER_THRESHOLD=50
DEEP_MAX_COMPS_PER_SITE=3

# HTTP API for WordPress dashboard on another server
COMPETITOR_API_PORT=3847
COMPETITOR_API_SECRET=change-me-to-long-random-string

# Residential proxy — required on datacenter servers (Cloudways) to bypass Cloudflare on Ryse/Royalux/D2R/MRG.
# Get credentials from: https://dashboard.smartproxy.com → Residential Proxies → Endpoint Generator
# Leave blank to scrape without proxy (works locally, blocked on datacenter IPs).
# SCRAPER_PROXY=http://user-spXXXXXXXX:your_password@gate.smartproxy.com:10000
