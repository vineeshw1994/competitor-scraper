# MySQL (WordPress database)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_wordpress_db

# Table prefix (WordPress)
DB_TABLE_PREFIX=wp_

# Scraper settings
SCRAPER_THRESHOLD=50
DEEP_MAX_SITES=3
DEEP_MAX_COMPS_PER_SITE=3
HEADLESS=true
REQUEST_DELAY_MS=1500
